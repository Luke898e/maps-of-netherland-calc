# Public site URL for canonical tags and structured data URLs
# Example: https://example.com
# Required in production.
NEXT_PUBLIC_SITE_URL=https://map-of-netherlands.co.uk

# Public contact email used across contact/support links
# Required in production.
NEXT_PUBLIC_CONTACT_EMAIL=

# Public maintainer profile used on About/Author sections
# Example: https://github.com/your-handle
# Required in production.
NEXT_PUBLIC_GITHUB_PROFILE=

# Google Privacy & Messaging (Funding Choices) script URL
# Paste the full script URL generated in your AdSense Privacy & Messaging setup.
# Example format:
# https://fundingchoicesmessages.google.com/i/pub-XXXXXXXXXXXXXXXX?ers=1
# Required in production.
NEXT_PUBLIC_GOOGLE_FC_SCRIPT_URL=

# Google AdSense publisher client id
# Example format:
# ca-pub-1234567890123456
# Required in production.
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT=
