# Public site URL for canonical tags and structured data URLs
# Example: https://example.com
# Required in production.
NEXT_PUBLIC_SITE_URL=https://map-of-netherlands.co.uk

# Public contact email used across contact/support links
# Required in production.
NEXT_PUBLIC_CONTACT_EMAIL=

# Public maintainer profile used on About/Author sections
# Example: https://github.com/your-handle
# Required in production.
NEXT_PUBLIC_GITHUB_PROFILE=

# Google Privacy & Messaging (Funding Choices) script URL
# Paste the full script URL generated in your AdSense Privacy & Messaging setup.
# Example format:
# https://fundingchoicesmessages.google.com/i/pub-XXXXXXXXXXXXXXXX?ers=1
# Required in production for consent-region ad serving readiness.
NEXT_PUBLIC_GOOGLE_FC_SCRIPT_URL=

# Google AdSense publisher client id
# Example format:
# ca-pub-1234567890123456
# Required in production for ad policy readiness.
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT=

# Do not submit for AdSense review until both values above are configured in production.

# Optional: support endpoint forwarding target
# If set, validated support form submissions are POSTed to this URL.
# Example: https://hooks.slack.com/services/...
SUPPORT_WEBHOOK_URL=

# Support API rate-limit mode
# auto (default): use Upstash if configured, otherwise in-memory fallback
# memory: always use in-memory limiter (single-instance only)
# upstash: require Upstash; if unavailable, fallback to in-memory limiter
# strict-global: require Upstash; fail closed with 503 if unavailable
SUPPORT_RATE_LIMIT_MODE=auto

# Optional: Upstash REST credentials for distributed/global support rate limiting
# Required for SUPPORT_RATE_LIMIT_MODE=upstash or strict-global
# Example:
# UPSTASH_REDIS_REST_URL=https://<id>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<token>
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Readiness page display mode
# false (default): hide unresolved action-required items in public view
# true: show full internal audit view with action-required items
NEXT_PUBLIC_READINESS_AUDIT_MODE=false

# Set to true only after the corresponding operational step is complete
NEXT_PUBLIC_CONSENT_CAMPAIGN_LIVE=false
NEXT_PUBLIC_ADSENSE_ACCOUNT_READY=false
NEXT_PUBLIC_PRODUCTION_QA_COMPLETE=false
